{
  "name": "rexvane-blog-writer",
  "version": "1.2.0",
  "description": "A dedicated desktop editor for RexVane.github.io",
  "main": "electron/main.cjs",
  "type": "module",
  "author": "RexVane",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "start": "npm run build:renderer && electron .",
    "build:renderer": "vite build",
    "generate:icon": "node scripts/generate-icon.cjs",
    "test": "node --test test/*.test.cjs",
    "test:e2e": "npm run build:renderer && playwright test",
    "capture": "npm run build:renderer && cross-env WRITER_CAPTURE_PATH=artifacts/writer.png electron .",
    "dist": "npm run generate:icon && npm run test && npm run build:renderer && electron-builder --win portable",
    "dist:mac": "npm run generate:icon && npm run test && npm run build:renderer && electron-builder --mac"
  },
  "dependencies": {
    "@fontsource-variable/noto-sans-sc": "5.2.10",
    "@fontsource-variable/noto-serif-sc": "5.2.10",
    "dompurify": "3.4.12",
    "gray-matter": "4.0.3",
    "lucide": "1.24.0",
    "marked": "18.0.6",
    "pinyin-pro": "3.28.1",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "concurrently": "10.0.3",
    "cross-env": "10.1.0",
    "electron": "42.0.0",
    "electron-builder": "26.15.3",
    "png-to-ico": "3.0.2",
    "sharp": "0.35.3",
    "vite": "8.1.4",
    "wait-on": "9.0.10"
  },
  "build": {
    "appId": "io.github.rexvane.blogwriter",
    "productName": "RexVane Writer",
    "artifactName": "RexVane-Writer-${version}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-renderer/**/*",
      "electron/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.productivity"
    }
  }
}
