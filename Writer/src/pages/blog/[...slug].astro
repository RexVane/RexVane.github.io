---
import PostLayout from '@/layouts/PostLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ id }) => id.startsWith('zh/'));
  return posts.map((post) => ({
    params: { slug: post.id.replace('zh/', '') },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await render(post);
---

<PostLayout title={post.data.title} description={post.data.description} pubDate={post.data.pubDate} tags={post.data.tags} heroImage={post.data.heroImage}>
  <Content />
</PostLayout>
