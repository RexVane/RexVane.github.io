---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="404" description="页面不存在 / Page not found">
  <div class="notfound">
    <p class="code">404</p>
    <h1 class="title">页面不存在 <span class="divider">/</span> Page not found</h1>
    <p class="desc">你访问的页面不存在或已被移动。The page you are looking for doesn't exist or has been moved.</p>
    <div class="actions">
      <a class="btn" href="/">返回首页</a>
      <a class="btn" href="/en/">Back to home</a>
    </div>
  </div>
</BaseLayout>

<style>
  .notfound {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 4rem 0;
  }

  .code {
    font-size: 5rem;
    font-weight: 700;
    color: rgba(123, 164, 219, 0.6);
    margin: 0;
    line-height: 1;
  }

  .title {
    font-size: 1.4rem;
    font-weight: 600;
    color: #fff;
    margin: 1rem 0 0.5rem;
  }

  .divider {
    color: rgba(224, 224, 224, 0.3);
    font-weight: 400;
  }

  .desc {
    font-size: 0.9rem;
    color: rgba(224, 224, 224, 0.6);
    max-width: 32rem;
    margin: 0 0 2rem;
  }

  .actions {
    display: flex;
    gap: 0.75rem;
  }

  .btn {
    padding: 0.6rem 1.25rem;
    border-radius: 0.6rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.04);
    color: rgba(224, 224, 224, 0.85);
    text-decoration: none;
    font-size: 0.9rem;
    transition: all 0.2s;
  }
  .btn:hover {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.25);
    background: rgba(255, 255, 255, 0.08);
  }
</style>
