---
import ListPage from '@/components/ListPage.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ id }) => id.startsWith('en/')))
  .filter((post) => !post.data.draft && post.data.category === 'Journal')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<ListPage
  title="Journal"
  description="Journal"
  heading="Journal"
  quote={'"Not all those who wander are lost." — J.R.R. Tolkien'}
  posts={posts}
/>
