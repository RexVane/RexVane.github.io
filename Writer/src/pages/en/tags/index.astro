---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ id }) => id.startsWith('en/'))).filter((post) => !post.data.draft);
const tagCounts = new Map<string, number>();
posts.forEach((post) => post.data.tags.forEach((tag) => tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1)));
const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="Tags" description="All tags">
  <h1 class="page-title">Tags</h1>
  <div class="tag-cloud">
    {tags.length === 0 && <p class="empty">No tags yet.</p>}
    {
      tags.map(([tag, count]) => (
        <a class="tag-chip" href={`/en/tags/${tag}/`}>
          #{tag}
          <span class="count">{count}</span>
        </a>
      ))
    }
  </div>
</BaseLayout>

<style>
  .page-title {
    font-size: 1.8rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 2rem;
  }

  .empty {
    color: #a1a1aa;
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .tag-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.85rem;
    border-radius: 0.6rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px) saturate(1.2);
    color: rgba(224, 224, 224, 0.8);
    text-decoration: none;
    font-size: 0.9rem;
    transition: all 0.2s;
  }
  .tag-chip:hover {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.25);
    background: rgba(255, 255, 255, 0.08);
    transform: translateY(-1px);
  }

  .count {
    font-size: 0.75rem;
    color: rgba(123, 164, 219, 0.9);
    background: rgba(123, 164, 219, 0.12);
    padding: 0.1rem 0.4rem;
    border-radius: 0.4rem;
  }
</style>
