---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProjectsGrid from '@/components/ProjectsGrid.astro';
---

<BaseLayout title="Projects" description="My open-source projects">
  <h1 class="page-title">Projects</h1>
  <p class="page-quote">"Talk is cheap. Show me the code." - Linus Torvalds</p>
  <ProjectsGrid />
</BaseLayout>

<style>
  .page-title {
    font-size: 1.8rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.5rem;
  }

  .page-quote {
    font-size: 0.85rem;
    color: #a1a1aa;
    font-style: italic;
    margin: 0 0 2rem;
  }
</style>
