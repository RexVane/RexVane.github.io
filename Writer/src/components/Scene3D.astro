---
---

<div class="scene-bg" aria-hidden="true" transition:persist="scene-bg">
  <canvas id="bg-canvas"></canvas>
  <div class="scene-shade"></div>
</div>
<div id="scene-config-panel" class="scene-config-panel" hidden transition:persist="scene-config-panel"></div>

<script>
  import type * as ThreeNS from 'three';

  const canvas = document.getElementById('bg-canvas') as HTMLCanvasElement | null;
  const configPanel = document.getElementById('scene-config-panel') as HTMLDivElement | null;
  const query = new URLSearchParams(window.location.search);
  const isConfigMode = query.has('sceneConfig');
  const isSceneOnly = query.has('sceneOnly');
  const storageKey = 'rexvane.scene3d.config';

  if (isSceneOnly) {
    document.body.classList.add('scene-only');
  }

  interface SceneConfig {
    fov: number;
    fitSize: number;
    modelX: number;
    modelY: number;
    modelZ: number;
    cameraX: number;
    cameraY: number;
    cameraZ: number;
    targetX: number;
    targetY: number;
    targetZ: number;
    rotationX: number;
    rotationY: number;
    exposure: number;
    ambient: number;
    keyLight: number;
    fillLight: number;
  }

  const defaultSceneConfig: SceneConfig = {
    fov: 42,
    fitSize: 10,
    modelX: 0,
    modelY: -0.22,
    modelZ: 0,
    cameraX: 8,
    cameraY: 0,
    cameraZ: 0,
    targetX: 0,
    targetY: 0,
    targetZ: 0,
    rotationX: 0,
    rotationY: 0,
    exposure: 1.4,
    ambient: 1.4,
    keyLight: 3,
    fillLight: 2,
  };

  const mobileSceneConfig: SceneConfig = {
    ...defaultSceneConfig,
    fov: 54,
    fitSize: 8.6,
    modelY: -0.16,
    cameraX: 8.8,
    cameraY: 0,
  };

  function readStoredConfig() {
    if (!isConfigMode) return { ...defaultSceneConfig };

    try {
      const stored = localStorage.getItem(storageKey);
      return stored ? { ...defaultSceneConfig, ...JSON.parse(stored) } : { ...defaultSceneConfig };
    } catch {
      return { ...defaultSceneConfig };
    }
  }

  function applyQueryOverrides(config: SceneConfig) {
    const next = { ...config };
    (Object.keys(defaultSceneConfig) as Array<keyof SceneConfig>).forEach((key) => {
      const value = query.get(key);
      if (value === null) return;

      const numberValue = Number(value);
      if (Number.isFinite(numberValue)) {
        next[key] = numberValue;
      }
    });
    return next;
  }

  let sceneConfig = applyQueryOverrides(readStoredConfig());

  // Three.js 全量约 650KB，动态 import 拆出主 bundle，空闲时再启动，
  // 首屏内容渲染不再被 3D 背景阻塞。
  async function initScene(canvasEl: HTMLCanvasElement) {
    const [THREE, { GLTFLoader }, { RoomEnvironment }, { MeshoptDecoder }] = await Promise.all([
      import('three'),
      import('three/examples/jsm/loaders/GLTFLoader.js'),
      import('three/examples/jsm/environments/RoomEnvironment.js'),
      import('three/examples/jsm/libs/meshopt_decoder.module.js'),
    ]);

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const scene = new THREE.Scene();
    scene.background = new THREE.Color(0x060609);

    const camera = new THREE.PerspectiveCamera(46, window.innerWidth / window.innerHeight, 0.05, 500);

    const renderer = new THREE.WebGLRenderer({
      canvas: canvasEl,
      antialias: true,
      alpha: false,
      powerPreference: 'high-performance',
    });

    function applyPixelRatio() {
      // 移动端遮罩已把背景压得很暗，降到 1x 省电且几乎无视觉差异
      const cap = window.innerWidth < 760 ? 1 : 1.5;
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, cap));
    }
    applyPixelRatio();
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = sceneConfig.exposure;
    renderer.outputColorSpace = THREE.SRGBColorSpace;

    const pmremGenerator = new THREE.PMREMGenerator(renderer);
    scene.environment = pmremGenerator.fromScene(new RoomEnvironment(), 0.04).texture;

    const ambientLight = new THREE.AmbientLight(0xffffff, sceneConfig.ambient);
    scene.add(ambientLight);

    const keyLight = new THREE.DirectionalLight(0xffe3ad, sceneConfig.keyLight);
    keyLight.position.set(0, 7, -4);
    scene.add(keyLight);

    const fillLight = new THREE.DirectionalLight(0x88d9ff, sceneConfig.fillLight);
    fillLight.position.set(-5, 3, 6);
    scene.add(fillLight);

    const modelRoot = new THREE.Group();
    scene.add(modelRoot);

    let modelReady = false;
    let mixer: ThreeNS.AnimationMixer | undefined;
    let targetZoom = 0;
    let zoom = 0;
    let loadedModel: ThreeNS.Group | undefined;
    let modelSourceCenter = new THREE.Vector3();
    let modelSourceMaxDim = 1;
    let needsRender = true;

    function setRendererSize() {
      const width = window.innerWidth;
      const height = window.innerHeight;

      renderer.setSize(width, height, false);
      camera.aspect = width / height;
      camera.updateProjectionMatrix();
    }

    function getActiveConfig() {
      const isSmallViewport = window.innerWidth < 760;
      return isSmallViewport && !isConfigMode ? mobileSceneConfig : sceneConfig;
    }

    function applyLighting() {
      renderer.toneMappingExposure = sceneConfig.exposure;
      ambientLight.intensity = sceneConfig.ambient;
      keyLight.intensity = sceneConfig.keyLight;
      fillLight.intensity = sceneConfig.fillLight;
    }

    function applyModelFit(fitSize: number) {
      if (!loadedModel) return;

      const scale = fitSize / modelSourceMaxDim;
      loadedModel.scale.setScalar(scale);
      loadedModel.position.copy(modelSourceCenter).multiplyScalar(-scale);
    }

    function applyRotation(config = getActiveConfig()) {
      modelRoot.rotation.x = config.rotationX;
      modelRoot.rotation.y = config.rotationY;
    }

    function stageScene() {
      const config = getActiveConfig();

      if (camera.fov !== config.fov) {
        camera.fov = config.fov;
        camera.updateProjectionMatrix();
      }

      modelRoot.position.set(config.modelX, config.modelY, config.modelZ);
      camera.position.set(config.cameraX, config.cameraY, config.cameraZ + zoom);
      camera.lookAt(config.targetX, config.targetY, config.targetZ);
      applyModelFit(config.fitSize);

      if (isConfigMode) {
        applyLighting();
      }
    }

    const loader = new GLTFLoader();
    loader.setMeshoptDecoder(MeshoptDecoder);
    loader.load(
      '/models/investigation_board.optimized.glb',
      (gltf) => {
        const model = gltf.scene;

        model.traverse((object) => {
          if ('isMesh' in object && object.isMesh) {
            const mesh = object as ThreeNS.Mesh;
            mesh.frustumCulled = false;

            if (mesh.material) {
              const materials = Array.isArray(mesh.material) ? mesh.material : [mesh.material];
              materials.forEach((material) => {
                material.side = THREE.DoubleSide;
                material.needsUpdate = true;
              });
            }
          }
        });

        const box = new THREE.Box3().setFromObject(model);
        modelSourceCenter = box.getCenter(new THREE.Vector3());
        const size = box.getSize(new THREE.Vector3());
        modelSourceMaxDim = Math.max(size.x, size.y, size.z);
        loadedModel = model;

        applyModelFit(getActiveConfig().fitSize);

        modelRoot.add(model);

        if (gltf.animations.length > 0) {
          mixer = new THREE.AnimationMixer(model);
          gltf.animations.forEach((clip) => {
            mixer?.clipAction(clip).play();
          });
        }

        stageScene();
        applyRotation();
        modelReady = true;
        needsRender = true;
      },
      undefined,
      (error) => {
        console.error('Error loading model:', error);
      }
    );

    setRendererSize();
    stageScene();
    applyRotation();

    const clock = new THREE.Clock();

    function saveConfig() {
      localStorage.setItem(storageKey, JSON.stringify(sceneConfig));
    }

    function createConfigPanel() {
      if (!isConfigMode || !configPanel) return;

      document.body.classList.add('scene-config-mode');
      configPanel.hidden = false;

      const controls: Array<{ key: keyof SceneConfig; label: string; min: number; max: number; step: number }> = [
        { key: 'fov', label: 'FOV', min: 35, max: 105, step: 1 },
        { key: 'fitSize', label: 'Scale', min: 6, max: 18, step: 0.1 },
        { key: 'modelX', label: 'Model X', min: -8, max: 8, step: 0.05 },
        { key: 'modelY', label: 'Model Y', min: -4, max: 4, step: 0.05 },
        { key: 'modelZ', label: 'Model Z', min: -8, max: 8, step: 0.05 },
        { key: 'cameraX', label: 'Camera X', min: -12, max: 12, step: 0.05 },
        { key: 'cameraY', label: 'Camera Y', min: -2, max: 4, step: 0.05 },
        { key: 'cameraZ', label: 'Camera Z', min: -12, max: 12, step: 0.05 },
        { key: 'targetX', label: 'Look X', min: -12, max: 12, step: 0.05 },
        { key: 'targetY', label: 'Look Y', min: -2, max: 4, step: 0.05 },
        { key: 'targetZ', label: 'Look Z', min: -12, max: 12, step: 0.05 },
        { key: 'rotationX', label: 'Pitch', min: -0.4, max: 0.4, step: 0.005 },
        { key: 'rotationY', label: 'Yaw', min: -0.8, max: 0.8, step: 0.005 },
        { key: 'exposure', label: 'Exposure', min: 0.4, max: 2.2, step: 0.02 },
        { key: 'ambient', label: 'Ambient', min: 0, max: 2, step: 0.02 },
        { key: 'keyLight', label: 'Key', min: 0, max: 4, step: 0.05 },
        { key: 'fillLight', label: 'Fill', min: 0, max: 3, step: 0.05 },
      ];

      configPanel.innerHTML = `
        <div class="scene-config-title">Scene Config</div>
        <div class="scene-config-controls">
          ${controls
            .map(
              (control) => `
                <label class="scene-control">
                  <span>${control.label}</span>
                  <output data-output="${control.key}">${sceneConfig[control.key].toFixed(2)}</output>
                  <input
                    data-key="${control.key}"
                    type="range"
                    min="${control.min}"
                    max="${control.max}"
                    step="${control.step}"
                    value="${sceneConfig[control.key]}"
                  />
                </label>
              `
            )
            .join('')}
        </div>
        <div class="scene-config-actions">
          <button type="button" data-action="copy">Copy JSON</button>
          <button type="button" data-action="reset">Reset</button>
        </div>
      `;

      configPanel.querySelectorAll<HTMLInputElement>('input[data-key]').forEach((input) => {
        input.addEventListener('input', () => {
          const key = input.dataset.key as keyof SceneConfig;
          const value = Number(input.value);
          sceneConfig = { ...sceneConfig, [key]: value };
          configPanel.querySelector<HTMLOutputElement>(`output[data-output="${key}"]`)!.value = value.toFixed(2);
          saveConfig();
          stageScene();
          applyRotation();
          needsRender = true;
        });
      });

      configPanel.querySelector<HTMLButtonElement>('button[data-action="copy"]')?.addEventListener('click', async () => {
        const json = JSON.stringify(sceneConfig, null, 2);
        console.log('Scene config:', json);
        await navigator.clipboard?.writeText(json);
      });

      configPanel.querySelector<HTMLButtonElement>('button[data-action="reset"]')?.addEventListener('click', () => {
        sceneConfig = { ...defaultSceneConfig };
        saveConfig();
        configPanel.querySelectorAll<HTMLInputElement>('input[data-key]').forEach((input) => {
          const key = input.dataset.key as keyof SceneConfig;
          input.value = String(sceneConfig[key]);
          configPanel.querySelector<HTMLOutputElement>(`output[data-output="${key}"]`)!.value = sceneConfig[key].toFixed(2);
        });
        stageScene();
        applyRotation();
        needsRender = true;
      });
    }

    createConfigPanel();

    function animate() {
      requestAnimationFrame(animate);
      const delta = clock.getDelta();

      const zooming = modelReady && Math.abs(targetZoom - zoom) > 0.0005;
      if (zooming) {
        zoom += (targetZoom - zoom) * 0.08;
        stageScene();
      }

      const animating = modelReady && mixer !== undefined && !reducedMotion;
      if (animating) {
        mixer!.update(delta);
      }

      // 静止且无动画时跳过渲染，不再空烧 GPU
      if (needsRender || zooming || animating) {
        renderer.render(scene, camera);
        needsRender = false;
      }
    }
    animate();

    window.addEventListener('resize', () => {
      applyPixelRatio();
      setRendererSize();
      stageScene();
      applyRotation();
      needsRender = true;
    });

    window.addEventListener(
      'wheel',
      (event) => {
        if (!event.altKey) return;

        event.preventDefault();
        targetZoom = THREE.MathUtils.clamp(targetZoom + event.deltaY * 0.0025, -0.75, 1.2);
      },
      { passive: false }
    );
  }

  if (canvas) {
    const start = () => {
      initScene(canvas).catch((error) => console.error('Scene3D init failed:', error));
    };
    if ('requestIdleCallback' in window) {
      window.requestIdleCallback(start, { timeout: 2000 });
    } else {
      window.setTimeout(start, 300);
    }
  }
</script>

<style>
  .scene-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background: #060609;
    overflow: hidden;
  }

  #bg-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 1;
    filter: brightness(0.9) saturate(0.94) contrast(1.02);
  }

  .scene-shade {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 50% 45%, rgba(6, 6, 9, 0), rgba(6, 6, 9, 0.16) 44%, rgba(6, 6, 9, 0.72) 94%),
      linear-gradient(90deg, rgba(6, 6, 9, 0.72) 0%, rgba(6, 6, 9, 0.22) 30%, rgba(6, 6, 9, 0.18) 62%, rgba(6, 6, 9, 0.68) 100%),
      linear-gradient(180deg, rgba(6, 6, 9, 0.42) 0%, rgba(6, 6, 9, 0.04) 45%, rgba(6, 6, 9, 0.82) 100%);
  }

  :global(body.scene-only .content),
  :global(body.scene-only .scene-config-panel) {
    display: none;
  }

  :global(.scene-config-panel) {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 300;
    width: min(21rem, calc(100vw - 2rem));
    max-height: min(44rem, calc(100vh - 2rem));
    overflow: auto;
    padding: 0.9rem;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 0.75rem;
    background: rgba(10, 10, 14, 0.9);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(18px) saturate(1.2);
    color: #f4f4f5;
    font: 500 0.78rem/1.3 system-ui, sans-serif;
    pointer-events: auto;
  }

  :global(.scene-config-panel[hidden]) {
    display: none;
  }

  :global(.scene-config-title) {
    margin-bottom: 0.75rem;
    font-size: 0.85rem;
    font-weight: 700;
  }

  :global(.scene-config-controls) {
    display: grid;
    gap: 0.55rem;
  }

  :global(.scene-control) {
    display: grid;
    grid-template-columns: 5.4rem 3.4rem 1fr;
    align-items: center;
    gap: 0.55rem;
  }

  :global(.scene-control span) {
    color: rgba(244, 244, 245, 0.76);
  }

  :global(.scene-control output) {
    color: rgba(244, 244, 245, 0.58);
    font-variant-numeric: tabular-nums;
    text-align: right;
  }

  :global(.scene-control input) {
    width: 100%;
    accent-color: #7ba4db;
  }

  :global(.scene-config-actions) {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.85rem;
  }

  :global(.scene-config-actions button) {
    flex: 1;
    padding: 0.45rem 0.55rem;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 0.5rem;
    background: rgba(255, 255, 255, 0.07);
    color: #f4f4f5;
    font: inherit;
    cursor: pointer;
  }

  :global(.scene-config-actions button:hover) {
    background: rgba(255, 255, 255, 0.12);
  }

  @media (max-width: 760px) {
    #bg-canvas {
      opacity: 0.78;
    }

    .scene-shade {
      background:
        radial-gradient(circle at 50% 42%, rgba(6, 6, 9, 0.04), rgba(6, 6, 9, 0.5) 58%, #060609 94%),
        linear-gradient(180deg, rgba(6, 6, 9, 0.58) 0%, rgba(6, 6, 9, 0.22) 38%, #060609 100%);
    }
  }
</style>
