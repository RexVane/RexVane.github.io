---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ id }) => id.startsWith('zh/')))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog" description="所有博客文章">
  <h1 class="page-title">Blog</h1>
  <div class="posts-list">
    {posts.map((post) => (
      <a class="post-card" href={`/blog/${post.id.replace('zh/', '')}`}>
        <div class="post-meta">
          <span class="post-category">{post.data.category}</span>
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('zh-CN')}
          </time>
        </div>
        <h2 class="post-title">{post.data.title}</h2>
        <p class="post-desc">{post.data.description}</p>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .page-title {
    font-size: 1.8rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 2rem;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .post-card {
    display: block;
    text-decoration: none;
    padding: 1.25rem 1.5rem;
    border-radius: 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(255, 255, 255, 0.02);
    transition: all 0.2s;
  }
  .post-card:hover {
    border-color: rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.04);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
    font-size: 0.8rem;
    color: rgba(224, 224, 224, 0.4);
  }

  .post-category {
    color: rgba(123, 164, 219, 0.8);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.7rem;
  }

  .post-title {
    font-size: 1.2rem;
    font-weight: 600;
    color: #fff;
    margin: 0 0 0.3rem;
  }

  .post-desc {
    font-size: 0.9rem;
    color: #a1a1aa;
    margin: 0;
  }
</style>
