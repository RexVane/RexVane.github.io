---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ id }) => id.startsWith('zh/')))
  .filter((post) => !post.data.draft && post.data.category === 'Journal')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Journal" description="随记">
  <h1 class="page-title">Journal</h1>
  <p class="page-quote">"Not all those who wander are lost." — J.R.R. Tolkien</p>
  <div class="posts-list">
    {posts.map((post) => (
      <a class="post-card" href={`/blog/${post.id.replace('zh/', '')}`}>
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('zh-CN')}
        </time>
        <h2 class="post-title">{post.data.title}</h2>
        <p class="post-desc">{post.data.description}</p>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .page-title {
    font-size: 1.8rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.5rem;
  }

  .page-quote {
    font-size: 0.85rem;
    color: #a1a1aa;
    font-style: italic;
    margin: 0 0 2rem;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .post-card {
    display: block;
    text-decoration: none;
    padding: 1.25rem 1.5rem;
    border-radius: 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(12px) saturate(1.2);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
    transition: all 0.3s ease;
  }
  .post-card:hover {
    border-color: rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.07);
    transform: translateY(-2px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.12),
      0 8px 24px rgba(0, 0, 0, 0.3);
  }

  .post-card time {
    font-size: 0.8rem;
    color: rgba(224, 224, 224, 0.4);
  }

  .post-title {
    font-size: 1.2rem;
    font-weight: 600;
    color: #fff;
    margin: 0.4rem 0 0.3rem;
  }

  .post-desc {
    font-size: 0.9rem;
    color: #a1a1aa;
    margin: 0;
  }
</style>
