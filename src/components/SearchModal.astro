---
---

<div id="search-modal" class="search-modal" hidden>
  <div class="search-backdrop" data-search-close></div>
  <div class="search-panel">
    <div class="search-head">
      <span class="search-title">搜索 · Search</span>
      <button class="search-close" data-search-close aria-label="Close">✕</button>
    </div>
    <div id="pagefind-container"></div>
    <p class="search-hint" id="search-dev-hint" hidden>
      搜索索引仅在生产构建中可用（npm run build）。Search index is only available in production builds.
    </p>
  </div>
</div>

<style>
  .search-modal {
    position: fixed;
    inset: 0;
    z-index: 400;
  }

  .search-modal[hidden] {
    display: none;
  }

  .search-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
  }

  .search-panel {
    position: relative;
    margin: 10vh auto 0;
    width: min(40rem, calc(100vw - 2rem));
    max-height: 72vh;
    overflow-y: auto;
    padding: 1rem 1.25rem 1.25rem;
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background: rgba(14, 14, 18, 0.92);
    backdrop-filter: blur(20px) saturate(1.2);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.5);
  }

  .search-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .search-title {
    font-size: 0.85rem;
    font-weight: 600;
    color: rgba(224, 224, 224, 0.7);
    letter-spacing: 0.03em;
  }

  .search-close {
    background: none;
    border: none;
    color: rgba(224, 224, 224, 0.6);
    font-size: 1rem;
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    border-radius: 0.4rem;
    transition: all 0.2s;
  }
  .search-close:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.08);
  }

  .search-hint {
    margin: 0.5rem 0 0;
    font-size: 0.8rem;
    color: rgba(224, 224, 224, 0.5);
  }

  .search-panel :global(#pagefind-container) {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: #7ba4db;
    --pagefind-ui-text: #e0e0e0;
    --pagefind-ui-background: rgba(255, 255, 255, 0.04);
    --pagefind-ui-border: rgba(255, 255, 255, 0.14);
    --pagefind-ui-tag: rgba(255, 255, 255, 0.08);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0.6rem;
    --pagefind-ui-font: inherit;
  }

  :global(body.search-open) {
    overflow: hidden;
  }
</style>

<script>
  let uiLoaded = false;
  let uiLoading = false;

  async function ensurePagefind(): Promise<boolean> {
    if (uiLoaded) return true;
    if (uiLoading) return false;
    uiLoading = true;
    try {
      if (!document.querySelector('link[data-pagefind-css]')) {
        const link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = '/pagefind/pagefind-ui.css';
        link.setAttribute('data-pagefind-css', 'true');
        document.head.appendChild(link);
      }
      await new Promise<void>((resolve, reject) => {
        const s = document.createElement('script');
        s.src = '/pagefind/pagefind-ui.js';
        s.onload = () => resolve();
        s.onerror = () => reject(new Error('pagefind-ui.js not found'));
        document.head.appendChild(s);
      });
      const PagefindUI = (window as unknown as { PagefindUI: new (opts: object) => unknown }).PagefindUI;
      new PagefindUI({ element: '#pagefind-container', showSubResults: true, showImages: false });
      uiLoaded = true;
      return true;
    } catch {
      return false;
    } finally {
      uiLoading = false;
    }
  }

  async function openSearch() {
    const modal = document.getElementById('search-modal');
    if (!modal) return;
    modal.hidden = false;
    document.body.classList.add('search-open');
    const ok = await ensurePagefind();
    const hint = document.getElementById('search-dev-hint');
    if (hint) hint.hidden = ok;
    if (ok) {
      const input = modal.querySelector<HTMLInputElement>('.pagefind-ui__search-input');
      input?.focus();
    }
  }

  function closeSearch() {
    const modal = document.getElementById('search-modal');
    if (!modal) return;
    modal.hidden = true;
    document.body.classList.remove('search-open');
  }

  document.addEventListener('click', (event) => {
    const target = event.target as HTMLElement;
    if (target.closest('#searchBtn')) {
      event.preventDefault();
      openSearch();
      return;
    }
    if (target.closest('[data-search-close]')) {
      closeSearch();
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeSearch();
    if ((event.ctrlKey || event.metaKey) && event.key.toLowerCase() === 'k') {
      event.preventDefault();
      openSearch();
    }
  });
</script>
