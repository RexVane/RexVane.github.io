---
import { getLangFromUrl } from '@/i18n/ui';

const lang = getLangFromUrl(Astro.url);
const isEn = lang === 'en';
---

<header class="site-header" id="site-header">
  <a class="brand" href={isEn ? '/en/' : '/'}>RexVane's Blog</a>
  <div class="nav-right">
    <nav class="nav-links">
      <div class="nav-dropdown">
        <a class="nav-item" href={isEn ? '/en/blog/' : '/blog/'}>
          Blog
          <svg class="chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
        </a>
        <div class="dropdown-menu">
          <a href={isEn ? '/en/blog/' : '/blog/'}>All</a>
          <a href={isEn ? '/en/blog/ai/' : '/blog/ai/'}>AI</a>
          <a href={isEn ? '/en/blog/technology/' : '/blog/technology/'}>Technology</a>
          <a href={isEn ? '/en/blog/insight/' : '/blog/insight/'}>Insight</a>
        </div>
      </div>
      <a class="nav-item" href={isEn ? '/en/projects/' : '/projects/'}>Projects</a>
      <a class="nav-item" href={isEn ? '/en/daily/' : '/daily/'}>Daily Life</a>
      <a class="nav-item" href={isEn ? '/en/journal/' : '/journal/'}>Journal</a>
    </nav>
    <div class="nav-actions">
      <button id="searchBtn" class="icon-btn" aria-label="Search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.3-4.3"/>
        </svg>
      </button>
      <a class="lang-switch" href={isEn ? '/' : '/en/'}>{isEn ? '中文' : 'EN'}</a>
      <button id="menuBtn" class="icon-btn menu-btn" aria-label="Menu" aria-expanded="false" aria-controls="mobile-menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>
  <nav class="mobile-menu" id="mobile-menu" hidden>
    <a href={isEn ? '/en/blog/' : '/blog/'}>Blog</a>
    <a class="sub" href={isEn ? '/en/blog/ai/' : '/blog/ai/'}>AI</a>
    <a class="sub" href={isEn ? '/en/blog/technology/' : '/blog/technology/'}>Technology</a>
    <a class="sub" href={isEn ? '/en/blog/insight/' : '/blog/insight/'}>Insight</a>
    <a href={isEn ? '/en/projects/' : '/projects/'}>Projects</a>
    <a href={isEn ? '/en/daily/' : '/daily/'}>Daily Life</a>
    <a href={isEn ? '/en/journal/' : '/journal/'}>Journal</a>
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    top: 1rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: calc(100% - 3rem);
    max-width: 72rem;
    margin-bottom: 3rem;
    padding: 0.75rem 0.5rem;
    border-radius: 1rem;
    border: 1px solid transparent;
    transition: all 0.3s;
  }

  .site-header.scrolled,
  .site-header.menu-open {
    padding: 0.6rem 1.5rem;
    border-color: rgba(255, 255, 255, 0.15);
    border-radius: 1.25rem;
    backdrop-filter: blur(20px) saturate(1.3);
    background: rgba(255, 255, 255, 0.05);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      0 8px 32px rgba(0, 0, 0, 0.4);
  }

  .site-header.scrolled {
    max-width: 56rem;
  }

  .brand {
    font-size: 1.4rem;
    font-weight: 600;
    color: #e0e0e0;
    text-decoration: none;
    transition: all 0.3s;
    white-space: nowrap;
  }
  .site-header.scrolled .brand {
    margin-left: 0.5rem;
  }
  .brand:hover {
    color: #fff;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .nav-dropdown {
    position: relative;
  }

  .nav-dropdown .nav-item {
    display: flex;
    align-items: center;
    gap: 0.2rem;
  }

  .chevron {
    transition: transform 0.2s;
  }
  .nav-dropdown:hover .chevron {
    transform: rotate(180deg);
  }

  .dropdown-menu {
    position: absolute;
    top: 100%;
    left: 0;
    margin-top: 0.5rem;
    min-width: 9rem;
    padding: 0.5rem;
    border-radius: 0.75rem;
    background: rgba(20, 20, 25, 0.95);
    border: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(16px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: all 0.2s ease;
    display: flex;
    flex-direction: column;
  }
  .nav-dropdown:hover .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .dropdown-menu a {
    color: rgba(224, 224, 224, 0.7);
    text-decoration: none;
    padding: 0.5rem 0.75rem;
    border-radius: 0.4rem;
    font-size: 0.9rem;
    transition: all 0.15s;
  }
  .dropdown-menu a:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.06);
  }

  .nav-item {
    color: rgba(224, 224, 224, 0.8);
    text-decoration: none;
    padding: 0.5rem 1.25rem;
    font-size: 1.1rem;
    font-weight: 500;
    transition: color 0.2s;
  }
  .nav-item:hover {
    color: #fff;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .icon-btn {
    background: none;
    border: none;
    color: rgba(224, 224, 224, 0.8);
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    transition: all 0.2s;
  }
  .icon-btn:hover {
    color: #fff;
  }

  .menu-btn {
    display: none;
  }

  .lang-switch {
    color: rgba(224, 224, 224, 0.8);
    text-decoration: none;
    font-size: 0.85rem;
    padding: 0.4rem 0.75rem;
    border-radius: 0.5rem;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .lang-switch:hover {
    color: #fff;
  }

  .mobile-menu {
    display: none;
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    right: 0;
    flex-direction: column;
    padding: 0.6rem;
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(14, 14, 18, 0.95);
    backdrop-filter: blur(20px) saturate(1.3);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.5);
  }

  .mobile-menu a {
    color: rgba(224, 224, 224, 0.8);
    text-decoration: none;
    padding: 0.65rem 0.9rem;
    border-radius: 0.5rem;
    font-size: 0.95rem;
    transition: all 0.15s;
  }
  .mobile-menu a:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.06);
  }
  .mobile-menu a.sub {
    padding-left: 2.1rem;
    font-size: 0.85rem;
    color: rgba(224, 224, 224, 0.6);
  }

  @media (max-width: 768px) {
    .site-header {
      top: 0.5rem;
      width: calc(100% - 1.5rem);
      padding: 0.5rem 0.75rem;
    }

    .nav-links {
      display: none;
    }

    .menu-btn {
      display: flex;
    }

    .mobile-menu:not([hidden]) {
      display: flex;
    }

    .brand {
      font-size: 1.15rem;
    }

    .nav-actions {
      gap: 0.25rem;
    }
  }
</style>

<script>
  function bindHeader() {
    const header = document.getElementById('site-header');
    if (!header || header.dataset.bound === 'true') return;
    header.dataset.bound = 'true';

    const onScroll = () => {
      if (window.scrollY > 20) {
        header.classList.add('scrolled');
      } else {
        header.classList.remove('scrolled');
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    document.addEventListener('astro:before-swap', () => window.removeEventListener('scroll', onScroll), { once: true });
    onScroll();

    const menuBtn = header.querySelector<HTMLButtonElement>('#menuBtn');
    const menu = header.querySelector<HTMLElement>('#mobile-menu');
    if (!menuBtn || !menu) return;

    const closeMenu = () => {
      menu.hidden = true;
      menuBtn.setAttribute('aria-expanded', 'false');
      header.classList.remove('menu-open');
    };

    menuBtn.addEventListener('click', () => {
      if (menu.hidden) {
        menu.hidden = false;
        menuBtn.setAttribute('aria-expanded', 'true');
        header.classList.add('menu-open');
      } else {
        closeMenu();
      }
    });

    menu.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeMenu));

    document.addEventListener('click', (event) => {
      if (!menu.hidden && !header.contains(event.target as Node)) closeMenu();
    });
  }

  bindHeader();
  document.addEventListener('astro:page-load', bindHeader);
</script>
