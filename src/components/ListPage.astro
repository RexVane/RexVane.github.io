---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/ui';
import type { CollectionEntry } from 'astro:content';

interface Props {
  title: string;
  description?: string;
  heading: string;
  quote?: string;
  posts: CollectionEntry<'blog'>[];
}

const { title, description = '', heading, quote, posts } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const prefix = lang === 'en' ? '/en' : '';
const dateLocale = lang === 'en' ? 'en-US' : 'zh-CN';
const dateFormat = {
  timeZone: 'Asia/Shanghai',
  year: 'numeric',
  month: 'short',
  day: 'numeric',
  hour: '2-digit',
  minute: '2-digit',
  hourCycle: 'h23',
} as const;
---

<BaseLayout title={title} description={description}>
  <h1 class="page-title">{heading}</h1>
  {quote && <p class="page-quote">{quote}</p>}
  <div class="posts-list">
    {posts.length === 0 && <p class="empty">{t('list.empty')}</p>}
    {
      posts.map((post) => (
        <a class="post-card" href={`${prefix}/blog/${post.id.replace(/^(zh|en)\//, '')}/`}>
          <div class="post-meta">
            <span class="post-category">{post.data.category}</span>
            <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleString(dateLocale, dateFormat)}</time>
          </div>
          <h2 class="post-title">{post.data.title}</h2>
          <p class="post-desc">{post.data.description}</p>
        </a>
      ))
    }
  </div>
</BaseLayout>

<style>
  .page-title {
    font-size: 1.8rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.5rem;
  }

  .page-quote {
    font-size: 0.85rem;
    color: #a1a1aa;
    font-style: italic;
    margin: 0 0 2rem;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .empty {
    color: #a1a1aa;
  }

  .post-card {
    display: block;
    text-decoration: none;
    padding: 1.25rem 1.5rem;
    border-radius: 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(12px) saturate(1.2);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
    transition: all 0.2s;
  }
  .post-card:hover {
    border-color: rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.05);
    transform: translateY(-2px);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
    font-size: 0.8rem;
    color: rgba(224, 224, 224, 0.4);
  }

  .post-category {
    color: rgba(123, 164, 219, 0.8);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.7rem;
  }

  .post-title {
    font-size: 1.2rem;
    font-weight: 600;
    color: #fff;
    margin: 0 0 0.3rem;
  }

  .post-desc {
    font-size: 0.9rem;
    color: #a1a1aa;
    margin: 0;
  }
</style>
