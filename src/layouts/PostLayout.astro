---
import BaseLayout from './BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/ui';

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  heroImage?: string;
}

const { title, description = '', pubDate, updatedDate, tags = [], heroImage } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const dateLocale = lang === 'en' ? 'en-US' : 'zh-CN';
const dateFormat = {
  timeZone: 'Asia/Shanghai',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  hour: '2-digit',
  minute: '2-digit',
  hourCycle: 'h23',
} as const;
---

<BaseLayout title={title} description={description} ogType="article" pubDate={pubDate} updatedDate={updatedDate}>
  <div class="post-layout">
    <article class="post-content" data-pagefind-body>
      {heroImage && (
        <div class="hero-image">
          <img src={heroImage} alt={title} />
        </div>
      )}
      <header class="post-header">
        <div class="post-meta">
          <time datetime={pubDate.toISOString()}>
            {pubDate.toLocaleString(dateLocale, dateFormat)}
          </time>
          {updatedDate && (
            <span class="post-updated">
              {t('post.updated')}
              <time datetime={updatedDate.toISOString()}>{updatedDate.toLocaleString(dateLocale, dateFormat)}</time>
            </span>
          )}
          {tags.length > 0 && (
            <div class="post-tags">
              {tags.map((tag) => <a class="tag" href={`${lang === 'en' ? '/en' : ''}/tags/${tag}/`}>#{tag}</a>)}
            </div>
          )}
        </div>
        <h1 class="post-title">{title}</h1>
      </header>
      <div class="prose">
        <slot />
      </div>
    </article>
    <aside class="toc-sidebar" id="toc-sidebar" data-pagefind-ignore>
      <h2 class="toc-title">{t('post.toc')}</h2>
      <nav id="toc-nav"></nav>
    </aside>
  </div>
</BaseLayout>

<style>
  .post-layout {
    display: flex;
    align-items: flex-start;
    gap: 2.5rem;
  }

  .post-content {
    min-width: 0;
    flex: 1;
  }

  .hero-image {
    margin-bottom: 1.5rem;
  }
  .hero-image img {
    width: 100%;
    max-width: 65ch;
    border-radius: 1rem;
    object-fit: cover;
  }

  .post-header {
    margin-bottom: 2.5rem;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    color: rgba(224, 224, 224, 0.6);
    font-size: 0.85rem;
    margin-bottom: 0.75rem;
  }

  .post-updated {
    display: inline-flex;
    gap: 0.35rem;
    color: rgba(224, 224, 224, 0.45);
  }

  .post-title {
    font-size: 2rem;
    font-weight: 700;
    color: #fff;
    margin: 0;
    line-height: 1.3;
  }

  .post-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.8rem;
    color: rgba(224, 224, 224, 0.6);
    text-decoration: none;
    transition: color 0.2s;
  }
  .tag:hover {
    color: #7ba4db;
  }

  .prose {
    line-height: 1.8;
    color: rgba(224, 224, 224, 0.9);
    max-width: 65ch;
  }

  .prose :global(h2) {
    font-size: 1.5rem;
    font-weight: 600;
    color: #fff;
    margin: 2.5rem 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .prose :global(h3) {
    font-size: 1.2rem;
    font-weight: 600;
    color: #f0f0f0;
    margin: 2rem 0 0.75rem;
  }

  .prose :global(p) {
    margin: 0 0 1.25rem;
  }

  .prose :global(a) {
    color: #7ba4db;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose :global(code) {
    background: rgba(255, 255, 255, 0.08);
    padding: 0.15rem 0.4rem;
    border-radius: 0.3rem;
    font-size: 0.85em;
  }

  .prose :global(pre) {
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 0.75rem;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
  }

  .prose :global(blockquote) {
    border-left: 3px solid rgba(255, 255, 255, 0.2);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: rgba(224, 224, 224, 0.7);
  }

  .prose :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 0.75rem;
  }

  .toc-sidebar {
    position: sticky;
    top: 5rem;
    min-width: 14rem;
    max-width: 18rem;
    max-height: calc(100vh - 6rem);
    overflow-y: auto;
    flex-shrink: 0;
    padding-left: 1.5rem;
    border-left: 1px solid rgba(255, 255, 255, 0.08);
  }

  .toc-title {
    font-size: 0.8rem;
    font-weight: 600;
    color: rgba(224, 224, 224, 0.6);
    letter-spacing: 0.05em;
    margin: 0 0 1rem;
  }

  @media (max-width: 768px) {
    .post-layout {
      flex-direction: column;
    }
    .toc-sidebar {
      display: none;
    }
    .post-title {
      font-size: 1.8rem;
    }
  }
</style>

<script>
  let tocObserver: IntersectionObserver | undefined;

  function buildToc() {
    const article = document.querySelector('.prose');
    const tocNav = document.getElementById('toc-nav');
    if (!article || !tocNav) return;

    tocObserver?.disconnect();
    tocNav.replaceChildren();

    const headings = article.querySelectorAll('h2, h3');
    if (headings.length === 0) return;

    const ul = document.createElement('ul');
    ul.style.cssText = 'list-style:none;padding:0;margin:0;';

    headings.forEach((heading, index) => {
      if (!heading.id) {
        heading.id = `section-${index}`;
      }
      const li = document.createElement('li');
      const a = document.createElement('a');
      a.href = `#${heading.id}`;
      a.textContent = heading.textContent;
      a.style.cssText = `
        display: block;
        padding: 0.3rem 0.75rem;
        margin-left: ${heading.tagName === 'H3' ? '1rem' : '0'};
        color: rgba(224,224,224,0.6);
        text-decoration: none;
        font-size: 0.85rem;
        border-left: 2px solid transparent;
        transition: all 0.2s;
      `;
      a.addEventListener('mouseenter', () => {
        a.style.color = '#fff';
      });
      a.addEventListener('mouseleave', () => {
        if (!a.classList.contains('active')) a.style.color = 'rgba(224,224,224,0.6)';
      });
      li.appendChild(a);
      ul.appendChild(li);
    });
    tocNav.appendChild(ul);

    tocObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const links = tocNav.querySelectorAll('a');
            links.forEach((link) => {
              link.classList.remove('active');
              link.style.color = 'rgba(224,224,224,0.6)';
              link.style.borderLeftColor = 'transparent';
            });
            const active = tocNav.querySelector(`a[href="#${entry.target.id}"]`) as HTMLAnchorElement;
            if (active) {
              active.classList.add('active');
              active.style.color = '#fff';
              active.style.borderLeftColor = '#7ba4db';
            }
          }
        });
      },
      { rootMargin: '-80px 0px -70% 0px' }
    );

    headings.forEach((h) => tocObserver!.observe(h));
  }

  buildToc();
  document.addEventListener('astro:page-load', buildToc);
</script>
